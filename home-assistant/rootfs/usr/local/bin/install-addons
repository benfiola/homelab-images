#!/bin/sh
set -e
rm -rf /config/custom_components /config/www /config/blueprints/automation /config/blueprints/script
mkdir -p /config/blueprints
cp -r /addons/custom_components /config/
cp -r /addons/www /config/
cp -r /addons/blueprints/automation /config/blueprints/
cp -r /addons/blueprints/script /config/blueprints/
